// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String
  github_username        String?   @unique
  github_user_id         String?   @unique
  github_installation_id String?   @unique
  projects               Project[]
}

model GithubInstallationPending {
  github_username String   @id          // GitHub login — globally unique, safe as PK
  installation_id String
  created_at      DateTime @default(now())
}

model Project {
  project_id     Int          @id @default(autoincrement())
  name           String
  description    String?
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  created_at     DateTime     @default(now())
  github_url     String
  build_cmd      String
  output_dir     String
  repoName       String
  build_branch   String
  primary_domain String
  deployments    Deployment[]
  project_env    Json?
}

model Deployment {
  deployment_id    Int      @id @default(autoincrement())
  project_id       Int
  project          Project  @relation(fields: [project_id], references: [project_id])
  created_at       DateTime @default(now())
  is_build_success Boolean?
  preview_url      String?
  is_production    Boolean  @default(false)
  build_logs       String?
}

model Domain {
  id              String   @id @default(cuid())
  domain_url      String   @unique
  deployment_id   Int?
  last_updated_at DateTime @default(now())

  @@index([domain_url])
}


model CustomDomain {
  id                String              @id @default(cuid())
  domain            String              @unique
  deployment_id     Int?
  project_id        Int?
  tenant_id         String?             // CloudFront Distribution Tenant ID
  tenant_arn        String?             // CloudFront Distribution Tenant ARN
  status            CustomDomainStatus  @default(PENDING)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
}

enum CustomDomainStatus {
  PENDING           // Tenant created, awaiting DNS + cert validation
  ACTIVE            // DNS verified, cert issued, serving traffic
  FAILED            // Something went wrong
}